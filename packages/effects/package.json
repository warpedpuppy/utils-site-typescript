{
  "name": "@utilspalooza/effects",
  "version": "0.0.0",
  "description": "Easy canvas background effects built from Utilspalooza creative-coding math.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "publishConfig": { "access": "public" },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
