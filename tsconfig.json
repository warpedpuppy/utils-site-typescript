{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@utilspalooza/core": ["./packages/core/src/index.ts"],
      "@utilspalooza/core/*": ["./packages/core/src/*"],
      "@utilspalooza/effects": ["./packages/effects/src/index.ts"],
      "@utilspalooza/effects/*": ["./packages/effects/src/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "useDefineForClassFields": true
  },
  "include": ["src", "packages/core/src", "packages/effects/src"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
